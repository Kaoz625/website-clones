{
  "name": "browser-automation",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "tsx": "^4.21.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "screenshot": "tsx scripts/screenshot.ts",
    "scrape": "tsx scripts/scrape-example.ts",
    "automate": "tsx scripts/form-fill-example.ts",
    "codegen": "npx playwright codegen",
    "verify:browsers": "playwright install --list",
    "form": "open form/index.html",
    "serve": "python3 -m http.server 3030",
    "test:form": "tsx scripts/test-form.ts",
    "scrape:dogwalkers": "tsx scripts/osint-scraper.ts --category 'dog walkers'",
    "scrape:dogwalkers:headless": "tsx scripts/osint-scraper.ts --category 'dog walkers' --headless",
    "scrape:osint": "tsx scripts/osint-scraper.ts",
    "scrape:osint:headless": "tsx scripts/osint-scraper.ts --headless",
    "comet:debug": "pkill -x Comet; sleep 1; open -a Comet --args --remote-debugging-port=9222 --remote-allow-origins=http://127.0.0.1:9222",
    "check:logins": "tsx scripts/check-ai-logins.ts",
    "ai:query": "tsx scripts/ai-query.ts",
    "ai:scan": "tsx scripts/ai-query.ts --scan-only",
    "browser:history": "tsx scripts/browser/scan-history.ts",
    "browser:bookmarks": "tsx scripts/browser/scan-bookmarks.ts",
    "research:test": "tsx scripts/research/web-search.ts",
    "research:reddit": "tsx scripts/research/reddit-search.ts",
    "securus:send": "tsx scripts/securus-message.ts",
    "securus:send:headless": "tsx scripts/securus-message.ts --headless",
    "securus:inbox": "tsx scripts/securus-check-inbox.ts",
    "securus:inbox:headless": "tsx scripts/securus-check-inbox.ts --headless",
    "securus:research": "tsx scripts/securus-research-reply.ts",
    "securus:research:headless": "tsx scripts/securus-research-reply.ts --headless",
    "securus:monitor": "tsx scripts/securus-monitor.ts",
    "securus:monitor:install": "tsx scripts/setup/install-monitor.ts",
    "uivision:record": "tsx scripts/uivision/record-login.ts",
    "uivision:build": "cd mcp-servers/uivision-mcp && npm run build",
    "uivision:start": "node mcp-servers/uivision-mcp/dist/index.js",
    "securus:test": "tsx scripts/securus-login-test.ts",
    "securus:test:headed": "COMET_HEADED=true tsx scripts/securus-login-test.ts headed",
    "securus:test:headless": "tsx scripts/securus-login-test.ts headless",
    "clone": "tsx scripts/clone-website.ts",
    "clone:lando": "tsx scripts/clone-website.ts https://landonorris.com/",
    "serve:clones": "python3 -m http.server 8080 --directory data/clones",
    "serve:lando": "python3 -m http.server 8080 --directory data/clones/landonorris.com",
    "clone:travis": "tsx scripts/clone-website.ts https://travisscott.com/",
    "clone:cr7": "tsx scripts/clone-website.ts https://cristiano.com/",
    "clone:awwwards": "tsx scripts/clone-website.ts https://awwwards.com/",
    "serve:travis": "python3 -m http.server 8081 --directory data/clones/travisscott.com",
    "serve:cr7": "python3 -m http.server 8082 --directory data/clones/cristiano.com",
    "serve:awwwards": "python3 -m http.server 8083 --directory data/clones/awwwards.com",
    "check": "tsc --noEmit && npm audit --audit-level=moderate",
    "check:install-hook": "tsx scripts/setup/install-pre-commit.ts",
    "bugbounty:headers": "tsx scripts/bugbounty/security-headers.ts",
    "bugbounty:redirects": "tsx scripts/bugbounty/open-redirect-scan.ts",
    "bugbounty:xss": "tsx scripts/bugbounty/xss-probe.ts",
    "bugbounty:info": "tsx scripts/bugbounty/info-disclosure.ts",
    "bugbounty:secrets": "tsx scripts/bugbounty/js-secrets.ts",
    "bugbounty:cors": "tsx scripts/bugbounty/cors-test.ts",
    "agent:peak:lead": "tsx scripts/agents/peak-hvac/lead-capture-agent.ts",
    "agent:peak:followup": "tsx scripts/agents/peak-hvac/followup-agent.ts",
    "agent:peak:schedule": "tsx scripts/agents/peak-hvac/scheduling-agent.ts",
    "agent:peak:chat": "tsx scripts/agents/peak-hvac/chat-widget-agent.ts",
    "agent:peak:reputation": "tsx scripts/agents/peak-hvac/reputation-monitor.ts",
    "agent:peak:noshow": "tsx scripts/agents/peak-hvac/no-show-recovery.ts",
    "agent:peak:review": "tsx scripts/agents/peak-hvac/review-generation.ts",
    "agent:peak:social": "tsx scripts/agents/peak-hvac/social-auto-poster.ts",
    "agent:peak:reactivate": "tsx scripts/agents/peak-hvac/lead-reactivation.ts",
    "agent:peak:compete": "tsx scripts/agents/peak-hvac/competitor-tracker.ts",
    "agent:peak:slots": "tsx scripts/agents/peak-hvac/smart-slot-filler.ts",
    "agent:clarity:chat": "tsx scripts/agents/clarity-coaching/chat-widget-agent.ts",
    "agent:clarity:qualify": "tsx scripts/agents/clarity-coaching/qualifier-agent.ts",
    "agent:clarity:nurture": "tsx scripts/agents/clarity-coaching/nurture-agent.ts",
    "agent:clarity:proposal": "tsx scripts/agents/clarity-coaching/proposal-agent.ts",
    "agent:luxe:book": "tsx scripts/agents/luxe-hair/booking-agent.ts",
    "agent:luxe:chat": "tsx scripts/agents/luxe-hair/chat-widget-agent.ts",
    "agent:luxe:reminder": "tsx scripts/agents/luxe-hair/reminder-agent.ts",
    "agent:luxe:retention": "tsx scripts/agents/luxe-hair/retention-agent.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "imapflow": "^1.3.2"
  }
}
